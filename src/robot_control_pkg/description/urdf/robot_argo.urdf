<?xml version="1.0"?>
<robot name="robot_argo">

  <link name="base_link"/>

  <!-- LiDAR -->
  <link name="laser"/>
  <joint name="laser_joint" type="fixed">
    <parent link="base_link"/>
    <child link="laser"/>
    <origin xyz="-0.145 0 0.30" rpy="0 0 0"/>
  </joint>

  <!-- IMU -->
  <link name="imu_link"/>
  <joint name="imu_joint" type="fixed">
    <parent link="base_link"/>
    <child link="imu_link"/>
    <origin xyz="0.19 -0.15 0.015" rpy="0 0 0"/>
  </joint>

</robot>
